# Public Firebase web configuration (safe to expose; database rules enforce access).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional Firebase App Check protection.
VITE_RECAPTCHA_SITE_KEY=

# Server-only credentials for /api/star and /api/sketch-visit.
# Prefer one JSON or base64-encoded JSON secret:
FIREBASE_SERVICE_ACCOUNT_KEY=
FIREBASE_DATABASE_URL=

# Or provide the service account fields separately:
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
